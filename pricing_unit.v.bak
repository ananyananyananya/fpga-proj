module pricing_unit#(
parameter K1=1,
parameter K2=2,
parameter MAX_EXPIRY=30,
parameter MIN_PRICE=10,
parameter MAX_PRICE=255
)(
input wire clk,
input wire rst,
input wire [7:0] base_price,
input wire [7:0] days_to_expiry,
input wire [7:0] demand_count,
output reg [7:0] final_price,
output reg is_discounted
);

reg signed [15:0] p_calc;
reg [15:0] expiry_discount;

always @(posedge clk or posedge rst) begin
if(rst) begin
final_price<=8'd0;
is_discounted<=1'b0;
end else begin
if(days_to_expiry<MAX_EXPIRY[7:0]) begin
expiry_discount=K2[7:0]*(MAX_EXPIRY[7:0]-days_to_expiry);
is_discounted<=1'b1;
end else begin
expiry_discount=8'd0;
is_discounted<=1'b0;
end

p_calc=$signed({1'b0,base_price})
+$signed({1'b0,K1[7:0]*demand_count})
-$signed({1'b0,expiry_discount});

if(p_calc<$signed({1'b0,MIN_PRICE[7:0]}))
final_price<=MIN_PRICE[7:0];
else if(p_calc>$signed({1'b0,MAX_PRICE[7:0]}))
final_price<=MAX_PRICE[7:0];
else
final_price<=p_calc[7:0];
end
end

endmodule
