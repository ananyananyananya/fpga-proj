module smart_vending_top(
input wire clk,
input wire rst,
input wire [2:0] product_sel,
input wire confirm,
input wire cancel,
input wire [1:0] pay_mode,
input wire coin_insert,
input wire [7:0] coin_value,
input wire [7:0] rfid_balance,
output wire [7:0] display_price,
output wire [7:0] display_balance,
output wire [7:0] display_change,
output wire [7:0] low_stock_leds,
output wire dispense_led,
output wire error_led,
output wire [3:0] ctrl_state,
output wire [2:0] pay_state,
output wire fifo_empty,
output wire [23:0] fifo_rd_data,
input wire fifo_rd_en,
output wire is_discounted
);

wire ram_we;
wire [2:0] ram_addr_a;
wire [31:0] ram_wdata_a;
wire [31:0] ram_rdata_a;

wire [7:0] pu_base_price;
wire [7:0] pu_days_expiry;
wire [7:0] pu_demand;
wire [7:0] pu_final_price;

wire pay_start;
wire pay_ok;
wire pay_cancel_sig;
wire pay_dispensing;
wire [7:0] pay_balance;
wire [7:0] pay_change;

wire fifo_wr_en;
wire [23:0] fifo_wr_data;
wire fifo_full;
wire [3:0] fifo_count;

inventory_ram u_ram(
.clk(clk),
.a_we(ram_we),
.a_addr(ram_addr_a),
.a_wdata(ram_wdata_a),
.a_rdata(ram_rdata_a),
.b_addr(3'd0),
.b_rdata()
);

pricing_unit #(
.K1(1),.K2(2),.MAX_EXPIRY(30),.MIN_PRICE(10),.MAX_PRICE(255)
) u_pricing(
.clk(clk),
.rst(rst),
.base_price(pu_base_price),
.days_to_expiry(pu_days_expiry),
.demand_count(pu_demand),
.final_price(pu_final_price),
.is_discounted(is_discounted)
);

payment_fsm u_payment(
.clk(clk),
.rst(rst),
.pay_start(pay_start),
.item_price(pu_final_price),
.cancel(cancel),
.pay_mode(pay_mode),
.coin_insert(coin_insert),
.coin_value(coin_value),
.rfid_balance(rfid_balance),
.balance(pay_balance),
.change_due(pay_change),
.pay_ok(pay_ok),
.pay_cancel(pay_cancel_sig),
.dispensing(pay_dispensing),
.state_out(pay_state)
);

tx_fifo #(
.DEPTH(16),.PTR_BITS(4),.DATA_BITS(24)
) u_fifo(
.clk(clk),
.rst(rst),
.wr_en(fifo_wr_en),
.wr_data(fifo_wr_data),
.full(fifo_full),
.rd_en(fifo_rd_en),
.rd_data(fifo_rd_data),
.empty(fifo_empty),
.count(fifo_count)
);

vending_controller u_ctrl(
.clk(clk),
.rst(rst),
.product_sel(product_sel),
.confirm(confirm),
.cancel(cancel),
.pay_mode(pay_mode),
.coin_insert(coin_insert),
.coin_value(coin_value),
.rfid_balance(rfid_balance),
.display_price(display_price),
.display_balance(display_balance),
.display_change(display_change),
.low_stock_leds(low_stock_leds),
.dispense_led(dispense_led),
.error_led(error_led),
.ctrl_state_out(ctrl_state),
.ram_we(ram_we),
.ram_addr(ram_addr_a),
.ram_wdata(ram_wdata_a),
.ram_rdata(ram_rdata_a),
.pu_base_price(pu_base_price),
.pu_days_expiry(pu_days_expiry),
.pu_demand(pu_demand),
.pu_final_price(pu_final_price),
.pu_is_discounted(is_discounted),
.pay_start(pay_start),
.pay_ok(pay_ok),
.pay_cancel(pay_cancel_sig),
.pay_dispensing(pay_dispensing),
.pay_balance(pay_balance),
.pay_change(pay_change),
.fifo_wr_en(fifo_wr_en),
.fifo_wr_data(fifo_wr_data),
.fifo_full(fifo_full)
);

endmodule
